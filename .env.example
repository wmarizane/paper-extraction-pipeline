# ================================
# Paper Extraction Pipeline Config
# ================================

# ===================================
# LLM Configuration
# ===================================
# Model selection for extraction
# Use HuggingFace model IDs (vLLM backend)
#   - Qwen/Qwen2.5-7B-Instruct   (fast baseline)
#   - Qwen/Qwen2.5-32B-Instruct  (higher quality)
#   - Qwen/Qwen3.5-27B           (if runtime stack supports it)
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Maximum tokens to generate per LLM response
VLLM_MAX_TOKENS=2048

# Maximum sequence length (leave empty for auto-detect)
VLLM_MAX_MODEL_LEN=

# LLM temperature (0.0=deterministic, higher=creative)
# Keep low (0.1-0.3) for factual extraction
LLM_TEMPERATURE=0.1

# Number of retry attempts on LLM failure
LLM_RETRY_ATTEMPTS=3

# LLM call timeout (seconds)
LLM_TIMEOUT=300

# === GROBID Configuration ===
# GROBID server URL for PDF parsing
# Local: http://localhost:8070
# Cluster: Dynamically set by SLURM script
GROBID_URL=http://localhost:8070

# === Text Chunking ===
# Strategy: "section" (by paper sections) or "paragraph" (by paragraphs)
CHUNK_STRATEGY=section

# Maximum tokens per chunk
CHUNK_SIZE=1024

# Token overlap between chunks for context
CHUNK_OVERLAP=100

# === Pipeline Paths ===
# Directory containing input PDFs
INPUT_DIR=./inputs

# Directory for extracted JSON outputs
OUTPUT_DIR=./results

# Directory for intermediate TEI XML files
TEI_XML_DIR=./tei_xml

# Log directory
LOG_DIR=./logs

# === Processing Options ===
# Enable batch processing of multiple PDFs
BATCH_MODE=true

# Number of PDFs to process in parallel (usually 1 for GPU)
PARALLEL_JOBS=1

# Enable checkpoint/resume capability
ENABLE_CHECKPOINT=true

# Checkpoint file location
CHECKPOINT_FILE=./checkpoint.json

# === Logging ===
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable JSON log output (for automated analysis)
JSON_LOGS=true

# Enable per-PDF log files
PER_PDF_LOGS=true

# ===================================
# LLM Extraction Settings
# ===================================
# Retry failed LLM calls (number of attempts)
LLM_RETRY_ATTEMPTS=3

# Timeout for LLM calls (seconds)
LLM_TIMEOUT=120

# Temperature for LLM (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.1

# vLLM runtime settings (used when extractor backend is vLLM)
VLLM_GPU_MEMORY=0.90
VLLM_MAX_MODEL_LEN=
VLLM_MAX_TOKENS=1200

# ===================================
# Extraction Schema
# ===================================
# Target extraction format (currently: polymer-lccc)
# Future: configurable schemas for different domains
EXTRACTION_SCHEMA=polymer-lccc

# ===================================
# Development/Debug Options
# ===================================
# Limit number of PDFs to process (0 = no limit)
MAX_PDFS=0

# Save intermediate outputs (TEI XML, chunks)
SAVE_INTERMEDIATE=false

# Verbose debugging output
DEBUG_MODE=false
