# Paper Extraction Pipeline Configuration
# Copy this file to .env and configure for your environment

# ===================================
# LLM Configuration
# ===================================
# Model selection for extraction
# Options: qwen3:4b, qwen3:8b, phi:mini (Ollama models)
LLM_MODEL=qwen3:4b

# Ollama server URL
# Local: http://localhost:11434
# Cluster: Set dynamically in SLURM script (port per job)
OLLAMA_URL=http://localhost:11434

# ===================================
# GROBID Configuration
# ===================================
# GROBID server for PDF parsing
GROBID_URL=http://localhost:8070

# ===================================
# Text Chunking Strategy
# ===================================
# Strategy: "section" (by paper sections) or "paragraph" (by paragraphs)
CHUNK_STRATEGY=section

# Maximum tokens per chunk (for LLM context window)
CHUNK_SIZE=1024

# Overlap between chunks (tokens) - helps maintain context
CHUNK_OVERLAP=100

# ===================================
# Pipeline Paths
# ===================================
# Input directory for PDFs
INPUT_DIR=./inputs

# Output directory for extracted JSON
OUTPUT_DIR=./results

# Log directory
LOG_DIR=./logs

# ===================================
# Processing Options
# ===================================
# Enable batch processing
BATCH_MODE=true

# Number of PDFs to process in parallel (if resources allow)
PARALLEL_JOBS=1

# Enable checkpoint/resume capability
ENABLE_CHECKPOINT=true

# Checkpoint file location
CHECKPOINT_FILE=./checkpoint.json

# ===================================
# Logging Configuration
# ===================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable JSON log output (for automated analysis)
JSON_LOGS=true

# Enable per-PDF log files
PER_PDF_LOGS=true

# ===================================
# LLM Extraction Settings
# ===================================
# Retry failed LLM calls (number of attempts)
LLM_RETRY_ATTEMPTS=3

# Timeout for LLM calls (seconds)
LLM_TIMEOUT=120

# Temperature for LLM (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.1

# ===================================
# Extraction Schema
# ===================================
# Target extraction format (currently: polymer-lccc)
# Future: configurable schemas for different domains
EXTRACTION_SCHEMA=polymer-lccc

# ===================================
# Development/Debug Options
# ===================================
# Limit number of PDFs to process (0 = no limit)
MAX_PDFS=0

# Save intermediate outputs (TEI XML, chunks)
SAVE_INTERMEDIATE=false

# Verbose debugging output
DEBUG_MODE=false
