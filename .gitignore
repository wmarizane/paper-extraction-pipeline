# Results JSONs: ignore only the per-run timestamped extraction archives
# (*_extracted_<timestamp>.json). The canonical per-model _latest.json and the
# final *_consensus.json ARE tracked — they are provenance for the dataset.
results/**/*.json
results/**/**/*.json
!results/**/*_latest.json
!results/consensus/**/*.json
logs/*.jsonl
logs/*.csv
